{
  "name": "killtheclipboard",
  "version": "0.2.0-alpha",
  "description": "SMART Health Link QR scanner — extracts FHIR records and PDFs from SHL QR codes",
  "keywords": [
    "fhir",
    "health-records",
    "qr-code",
    "smart-health-link"
  ],
  "license": "MIT",
  "author": "Amy Gleason",
  "bin": {
    "shl-scan": "./bin/shl-scan.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "start": "node packages/sidecar/server.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "scan": "node bin/shl-scan.js",
    "build": "npm run build -w @ktc/scanner",
    "dev": "npm run pack:core && npx serve packages/scanner/dist/core -p 3000",
    "pack:core": "node scripts/pack-core.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "googleapis": "^171.4.0",
    "jose": "^4.15.9",
    "jsqr": "^1.4.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "oxfmt": "^0.19.0",
    "oxlint": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "vitest": "^2.1.0"
  }
}
