# --- Proxy configuration ---

# Port to listen on (default: 3080)
PORT=3080

# Log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# Allowed CORS origins, comma-separated (default: * — allow all)
# Restrict in production to the scanner's origin(s).
# ALLOWED_ORIGINS=https://scanner.example.com,https://kiosk.example.com
