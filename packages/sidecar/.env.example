# --- Sidecar configuration ---

# Port to listen on (default: 3090)
PORT=3090

# REQUIRED — used for JWT signing and token encryption at rest.
# Must be at least 32 characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Path to SQLite database file (default: ./data/ktc.db)
DATABASE_PATH=./data/ktc.db

# Log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# --- SMTP (for storage_type: email) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Kill the Clipboard <noreply@example.com>

# --- Google Drive (for storage_type: drive) ---
# Configure via config.json or env vars:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_DRIVE_FOLDER=https://drive.google.com/drive/folders/...

# --- API (for storage_type: api) ---
# API_URL=https://api.example.com/ingest
# API_AUTH_HEADER=Bearer ...

# --- General ---
# PUBLIC_URL=https://sidecar.example.com
# RECIPIENT=Killtheclipboard
